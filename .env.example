# LLM
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# App environment: development | production | test
ENVIRONMENT=development

# Observability
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=threat-intel-agent

# Threat Intel APIs (all optional — mock fallback used if missing)
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
OTX_API_KEY=
SHODAN_API_KEY=
NVD_API_KEY=

# App config
LOG_LEVEL=INFO
MOCK_MODE=false
MAX_TOKENS=1024
RATE_LIMIT_BUFFER=0.8

# API server (FastAPI backend for the chat UI)
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOW_ORIGINS=http://localhost:3000
SESSION_TTL_SECONDS=3600
